#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HUNK_DIR="$SCRIPT_DIR"
HUNK_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/hunk"
HUNK_CONFIG_FILE="$HUNK_CONFIG_DIR/config.toml"
HUNK_PACKAGE="hunkdiff"
HUNK_GIT_ALIAS_DIFF='-c core.pager="hunk pager" diff'
HUNK_GIT_ALIAS_SHOW='-c core.pager="hunk pager" show'
HUNK_NPM_PREFIX="$HOME/.npm-global"

# shellcheck disable=SC1091
source "$SCRIPT_DIR/../lib/nix.sh"

check_installed() {
    bootstrap_node_tooling_path >/dev/null 2>&1 || true
    command -v hunk &>/dev/null
}

check_configured() {
    [[ -L "$HUNK_CONFIG_FILE" ]] || return 1
    command -v git &>/dev/null || return 1
    [[ "$(git config --global --get alias.hdiff 2>/dev/null)" == "$HUNK_GIT_ALIAS_DIFF" ]] || return 1
    [[ "$(git config --global --get alias.hshow 2>/dev/null)" == "$HUNK_GIT_ALIAS_SHOW" ]] || return 1
    return 0
}

install() {
    # Make sure node/npm are present (from the nix flake profile).
    nix_profile_sync
    _source_nix_env || true
    bootstrap_node_tooling_path >/dev/null 2>&1 || true

    if ! command -v npm &>/dev/null; then
        echo "npm not on PATH after nix sync — something is wrong"
        return 1
    fi

    setup_npm_global_prefix "$HUNK_NPM_PREFIX"

    if command -v hunk &>/dev/null; then
        echo "hunk already installed: $(hunk --version | head -1)"
        return 0
    fi

    echo "Installing hunk via npm..."
    npm install -g "$HUNK_PACKAGE"
    echo "hunk installed: $(hunk --version | head -1)"
}

configure() {
    mkdir -p "$HUNK_CONFIG_DIR"
    ln -sfn "$HUNK_DIR/config.toml" "$HUNK_CONFIG_FILE"
    if command -v git &>/dev/null; then
        git config --global alias.hdiff "$HUNK_GIT_ALIAS_DIFF"
        git config --global alias.hshow "$HUNK_GIT_ALIAS_SHOW"
    fi
}

update() {
    nix_profile_sync
    _source_nix_env || true
    bootstrap_node_tooling_path >/dev/null 2>&1 || true

    if command -v npm &>/dev/null; then
        setup_npm_global_prefix "$HUNK_NPM_PREFIX"
        echo "Updating hunk via npm..."
        npm update -g "$HUNK_PACKAGE"
    fi
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    install
    configure
fi
