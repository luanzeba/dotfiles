#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/../lib/nix.sh"

check_installed() {
    command -v node &>/dev/null
}

check_configured() {
    command -v tsc &>/dev/null \
        && command -v typescript-language-server &>/dev/null \
        && command -v prettier &>/dev/null \
        && command -v tree-sitter &>/dev/null
}

install() {
    nix_profile_sync
}

configure() {
    # All node-based tools come from the same nix profile; install() handles them.
    :
}

update() {
    nix_profile_sync
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    install
    configure
fi
