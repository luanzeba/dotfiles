#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/lib/common.sh"

FAILED_STEPS=()

# Helper to run a step and track failures with persistent error logging
run_step() {
    local name="$1"
    shift
    local output
    local exit_code

    output=$("$@" 2>&1)
    exit_code=$?

    if [[ $exit_code -ne 0 ]]; then
        FAILED_STEPS+=("$name")
        log_error_persistent "install" "$name" "$exit_code" "$output"
        echo "⚠️  $name failed, continuing..."
        echo "$output"
    else
        [[ -n "$output" ]] && echo "$output"
    fi
}

echo '🚀 Starting Codespaces setup.'

# Ensure zsh is default shell
ensure_zsh_default() {
    if [[ "$SHELL" != */zsh ]]; then
        sudo chsh -s "$(which zsh)" "$(whoami)"
    fi
}

# Setup codespace friendly name for shell prompt
setup_friendly_name() {
    if [[ -z "${CODESPACE_NAME:-}" ]]; then
        echo "Skipping friendly name setup (not a hosted Codespace)"
        return 0
    fi

    local friendly_name
    friendly_name=$(gh api "/user/codespaces/$CODESPACE_NAME" -q .display_name 2>/dev/null || true)
    if [[ -n "$friendly_name" && "$friendly_name" != *"Not Found"* ]]; then
        echo "$friendly_name" > "$HOME/.friendly_name"
    fi
}

# Install remote-development-manager for copy/paste and open support
install_rdm() {
    if [[ -z "${CODESPACE_NAME:-}" ]]; then
        echo "Skipping rdm install (not a hosted Codespace)"
        return 0
    fi

    local arch
    case "$(uname -m)" in
        x86_64) arch="amd64" ;;
        arm64|aarch64) arch="arm64" ;;
        *)
            echo "Warning: unsupported architecture for rdm: $(uname -m); skipping"
            return 0
            ;;
    esac

    # Some upstream latest releases may be published without binaries.
    # Pick the newest release that actually includes rdm-linux-<arch>.
    local url
    url=$(curl -fsSL https://api.github.com/repos/BlakeWilliams/remote-development-manager/releases | \
        jq -r --arg arch "$arch" '.[] | select((.assets | length) > 0) | .assets[] | select(.name == ("rdm-linux-" + $arch)) | .browser_download_url' | \
        head -n1)

    if [[ -z "$url" || "$url" == "null" ]]; then
        echo "Warning: could not find rdm-linux-${arch} release asset; skipping"
        return 0
    fi

    echo "Installing rdm from $url..."
    if ! curl -fsSL "$url" -o /tmp/rdm; then
        echo "Warning: failed to download rdm from $url; skipping"
        return 0
    fi

    if [[ ! -s /tmp/rdm ]]; then
        echo "Warning: downloaded rdm is empty; skipping"
        return 0
    fi

    if ! sudo install -m 0755 /tmp/rdm /usr/bin/rdm; then
        echo "Warning: failed to install rdm to /usr/bin/rdm; skipping"
        rm -f /tmp/rdm
        return 0
    fi

    rm -f /tmp/rdm
    gh config set browser "rdm open" 2>/dev/null || true
}

# Install ruby-lsp for GitHub monolith
setup_ruby_lsp() {
    if [[ -d "/workspaces/github" ]]; then
        echo "Setting up ruby-lsp for GitHub monolith..."
        export RAILS_ROOT="/workspaces/github"
        export PATH="$RAILS_ROOT/vendor/ruby/$(/workspaces/github/config/ruby-version)/bin:$PATH"
        gem install ruby-lsp

        # Symlink Ruby tools
        if [[ -d "/workspaces/github/bin" ]]; then
            sudo ln -sf /workspaces/github/bin/rubocop /usr/local/bin/rubocop
            sudo ln -sf /workspaces/github/bin/srb /usr/local/bin/srb
            sudo ln -sf /workspaces/github/bin/solargraph /usr/local/bin/solargraph
        fi
    fi
}

# Install system packages
install_apt_packages() {
    echo "Installing apt packages..."
    sudo apt-get update

    local packages=(
        build-essential
        python3-venv
        ruby-dev
        fd-find
        fzf
        bat
        jq
        ripgrep
        tmux
        libfuse2
        fuse
        software-properties-common
    )

    if apt-cache show eza >/dev/null 2>&1; then
        packages+=(eza)
    elif apt-cache show exa >/dev/null 2>&1; then
        packages+=(exa)
    else
        echo "Warning: neither eza nor exa is available from apt"
    fi

    sudo apt-get -o DPkg::Lock::Timeout=600 install -y "${packages[@]}"
}

# Main execution
log_info "Installing apt packages"
run_step "apt packages" install_apt_packages

log_info "Configuring tools"
run_step "git/install" bash "$SCRIPT_DIR/git/install"
run_step "tmux/install" bash "$SCRIPT_DIR/tmux/install"
run_step "bin/install" bash "$SCRIPT_DIR/bin/install"
run_step "gh/install" bash "$SCRIPT_DIR/gh/install"
run_step "skills/install" bash "$SCRIPT_DIR/skills/install"

log_info "Installing languages and tools"
run_step "rust/install" bash "$SCRIPT_DIR/rust/install"
run_step "go/install" bash "$SCRIPT_DIR/go/install"
run_step "node/install" bash "$SCRIPT_DIR/node/install"
run_step "pi/install" bash "$SCRIPT_DIR/pi/install"
run_step "opencode/install" bash "$SCRIPT_DIR/opencode/install"

log_info "Setting up shell"
run_step "ensure zsh default" ensure_zsh_default
run_step "zsh/install.zsh" zsh "$SCRIPT_DIR/zsh/install.zsh"

log_info "Setting up editors"
run_step "nvim/install" zsh "$SCRIPT_DIR/nvim/install"
run_step "helix/install" bash "$SCRIPT_DIR/helix/install"

log_info "Codespaces-specific setup"
run_step "setup friendly name" setup_friendly_name
run_step "install rdm" install_rdm
run_step "setup ruby-lsp" setup_ruby_lsp

# Report any failures
if [[ ${#FAILED_STEPS[@]} -gt 0 ]]; then
    echo ""
    echo "⚠️  The following steps failed:"
    for step in "${FAILED_STEPS[@]}"; do
        echo "  - $step"
    done
    echo ""
    echo "Run 'dot logs' for error details."
    log_warn "Codespaces setup completed with errors"
else
    log_success "Codespaces setup complete!"
fi
