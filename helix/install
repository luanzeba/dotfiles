#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HELIX_CONFIG_DIR="$HOME/.config/helix"
OLD_HELIX_INSTALL_DIR="$HOME/.local/helix"

# shellcheck disable=SC1091
source "$SCRIPT_DIR/../lib/nix.sh"

bootstrap_helix_path() {
    _source_nix_env || true
    if [[ -d "$HOME/.nix-profile/bin" ]]; then
        export PATH="$HOME/.nix-profile/bin:$PATH"
    fi
}

check_installed() {
    if ! nix_profile_has_entry "$NIX_HELIX_PROFILE_NAME"; then
        return 1
    fi

    bootstrap_helix_path
    command -v hx &>/dev/null
}

check_configured() {
    [[ -L "$HELIX_CONFIG_DIR/config.toml" ]] \
        && [[ -L "$HELIX_CONFIG_DIR/languages.toml" ]] \
        && [[ -L "$HELIX_CONFIG_DIR/runtime" ]] \
        && [[ -d "$HELIX_CONFIG_DIR/runtime" ]]
}

get_installed_version() {
    bootstrap_helix_path
    if command -v hx &>/dev/null; then
        hx --version 2>/dev/null
    fi
}

install() {
    nix_profile_sync_helix
}

helix_runtime_path() {
    bootstrap_helix_path

    command -v strings &>/dev/null || return 1

    local hx_path
    hx_path="$(command -v hx 2>/dev/null)" || return 1

    strings "$hx_path" 2>/dev/null | sed -n 's/^HELIX_RUNTIME=//p' | head -1
}

configure_runtime_symlink() {
    local runtime_link="$HELIX_CONFIG_DIR/runtime"
    local runtime_path=""
    runtime_path="$(helix_runtime_path || true)"

    if [[ -n "$runtime_path" && -d "$runtime_path" ]]; then
        ln -sfn "$runtime_path" "$runtime_link"
        return 0
    fi

    # Old direct-release installs linked runtime to ~/.local/helix/runtime.
    # If we cannot determine the Nix runtime, at least remove stale old links.
    if [[ -L "$runtime_link" ]]; then
        local target
        target="$(readlink "$runtime_link")"
        if [[ "$target" == "$OLD_HELIX_INSTALL_DIR/runtime" || ! -e "$runtime_link" ]]; then
            rm -f "$runtime_link"
            echo "Removed stale Helix runtime symlink: $runtime_link"
        fi
    fi
}

configure() {
    mkdir -p "$HELIX_CONFIG_DIR"
    ln -sf "$SCRIPT_DIR/config.toml" "$HELIX_CONFIG_DIR/config.toml"
    ln -sf "$SCRIPT_DIR/languages.toml" "$HELIX_CONFIG_DIR/languages.toml"
    configure_runtime_symlink
}

apply() {
    # Helix reads config on startup, nothing to reload.
    :
}

update() {
    nix_profile_sync_helix
    configure
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    install
    configure
fi
