#!/bin/bash
set -e

# Whisper - OpenAI's speech recognition model
# https://github.com/openai/whisper

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/../lib/nix.sh"

WHISPER_COMMANDS=(whisper)

bootstrap_whisper_path() {
    _source_nix_env || true
    if [[ -d "$HOME/.nix-profile/bin" ]]; then
        export PATH="$HOME/.nix-profile/bin:$PATH"
    fi
}

whisper_commands_available() {
    bootstrap_whisper_path

    local cmd
    for cmd in "${WHISPER_COMMANDS[@]}"; do
        command -v "$cmd" &>/dev/null || return 1
    done
}

check_installed() {
    if ! nix_profile_has_entry "$NIX_WHISPER_PROFILE_NAME"; then
        return 1
    fi

    whisper_commands_available
}

get_installed_version() {
    bootstrap_whisper_path

    local parts=()

    if command -v whisper &>/dev/null; then
        local whisper_version=""
        whisper_version=$(grep -o 'python[0-9.]*-whisper-[^/]*' "$(command -v whisper)" 2>/dev/null \
            | head -1 \
            | sed 's/^python[0-9.]*-whisper-//')
        parts+=("whisper ${whisper_version:-available}")
    fi

    local joined=""
    local part
    for part in "${parts[@]}"; do
        if [[ -n "$joined" ]]; then
            joined+=", "
        fi
        joined+="$part"
    done
    echo "$joined"
}

install() {
    nix_profile_sync_whisper
}

configure() {
    # No configuration needed.
    :
}

update() {
    nix_profile_sync_whisper
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    install
    configure
fi
