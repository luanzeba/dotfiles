#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/../lib/nix.sh"

bootstrap_nvim_path() {
    _source_nix_env || true
    if [[ -d "$HOME/.nix-profile/bin" ]]; then
        export PATH="$HOME/.nix-profile/bin:$PATH"
    fi
}

check_installed() {
    if ! nix_profile_has_entry "$NIX_NVIM_PROFILE_NAME"; then
        return 1
    fi

    bootstrap_nvim_path
    command -v nvim &>/dev/null
}

check_configured() {
    [[ -L "$HOME/.config/nvim" ]]
}

get_installed_version() {
    bootstrap_nvim_path
    if command -v nvim &>/dev/null; then
        nvim --version 2>/dev/null | head -1
    fi
}

install() {
    nix_profile_sync_nvim
}

configure() {
    # Symlink nvim config
    mkdir -p "$HOME/.config"
    if [[ ! -e "$HOME/.config/nvim" ]]; then
        ln -s "$SCRIPT_DIR" "$HOME/.config/nvim"
    elif [[ -L "$HOME/.config/nvim" ]]; then
        ln -sfn "$SCRIPT_DIR" "$HOME/.config/nvim"
    fi

    bootstrap_nvim_path

    if ! command -v nvim &>/dev/null; then
        echo "Neovim not found, skipping plugin installation"
        return 0
    fi

    local nvim_path
    nvim_path=$(command -v nvim)

    # Install plugins and required language tooling
    "$nvim_path" --headless "+Lazy! sync" +qa 2>/dev/null || true
    "$nvim_path" --headless "+MasonInstall ruby-lsp" +qa 2>/dev/null || true
}

apply() {
    bootstrap_nvim_path

    # Nvim reads config on startup, nothing to reload.
    # But we can sync plugins.
    if command -v nvim &>/dev/null; then
        nvim --headless "+Lazy! sync" +qa 2>/dev/null || true
    fi
}

update() {
    local current_version=""
    current_version=$(get_installed_version || true)

    nix_profile_sync_nvim
    bootstrap_nvim_path

    local new_version=""
    new_version=$(get_installed_version || true)
    echo "Updated: ${current_version:-not installed} -> ${new_version:-unknown}"

    # Update plugins and language tooling
    if command -v nvim &>/dev/null; then
        nvim --headless "+Lazy! sync" +qa 2>/dev/null || true
        nvim --headless "+MasonUpdate" +qa 2>/dev/null || true
    fi
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    install
    configure
fi
