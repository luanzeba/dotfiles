#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
VICINAE_CONFIG_DIR="$CONFIG_HOME/vicinae"
VICINAE_SETTINGS_FILE="$VICINAE_CONFIG_DIR/settings.json"
VICINAE_BASE_LINK="$VICINAE_CONFIG_DIR/base.jsonc"
VICINAE_SCRIPTS_LINK="$DATA_HOME/vicinae/scripts"
VICINAE_THEMES_DIR="$DATA_HOME/vicinae/themes"
VICINAE_EVERFOREST_THEME_LINK="$VICINAE_THEMES_DIR/everforest.toml"
VICINAE_APPLICATIONS_DIR="$DATA_HOME/applications"
VICINAE_SHORTCUTS_FILE="$DATA_HOME/vicinae/shortcuts/shortcuts.json"
VICINAE_SERVICE_LINK="$HOME/.config/systemd/user/vicinae.service"

# shellcheck disable=SC1091
source "$SCRIPT_DIR/../lib/nix.sh"

supported_platform() {
    is_arch
}

bootstrap_vicinae_path() {
    _source_nix_env || true
    if [[ -d "$HOME/.nix-profile/bin" ]]; then
        export PATH="$HOME/.nix-profile/bin:$PATH"
    fi
}

input_helper_current() {
    [[ -x /run/wrappers/bin/vicinae-input-server ]] || return 1
    [[ -x /usr/local/libexec/vicinae-input-server ]] || return 1

    bootstrap_vicinae_path
    local vicinae_bin helper
    vicinae_bin="$(readlink -f "$(command -v vicinae)")"
    helper="${vicinae_bin%/bin/vicinae}/libexec/vicinae/.vicinae-input-server-wrapped"

    [[ -x "$helper" ]] \
        && cmp -s "$helper" /usr/local/libexec/vicinae-input-server \
        && getcap /usr/local/libexec/vicinae-input-server | grep -q 'cap_dac_override=ep'
}

check_installed() {
    supported_platform || return 0
    nix_profile_has_entry "$NIX_VICINAE_PROFILE_NAME" || return 1
    bootstrap_vicinae_path
    command -v vicinae &>/dev/null
}

check_configured() {
    supported_platform || return 0

    [[ -L "$VICINAE_BASE_LINK" ]] \
        && [[ -f "$VICINAE_SETTINGS_FILE" ]] \
        && [[ -L "$VICINAE_SCRIPTS_LINK" ]] \
        && [[ -f "$VICINAE_APPLICATIONS_DIR/vicinae.desktop" ]] \
        && [[ -f "$VICINAE_APPLICATIONS_DIR/vicinae-url-handler.desktop" ]] \
        && [[ -L "$VICINAE_SERVICE_LINK" ]] \
        && input_helper_current
}

get_installed_version() {
    bootstrap_vicinae_path
    if command -v vicinae &>/dev/null; then
        vicinae version 2>/dev/null | head -1
    fi
}

install() {
    if ! supported_platform; then
        echo "Vicinae is only installed on Arch desktop systems; skipping"
        return 0
    fi

    nix_profile_sync_vicinae
}

backup_real_path() {
    local path="$1"

    if [[ -e "$path" && ! -L "$path" ]]; then
        local backup="${path}.backup.$(date +%s)"
        mv "$path" "$backup"
        echo "Backed up existing path to $backup"
    else
        rm -f "$path"
    fi
}

create_initial_settings() {
    [[ -e "$VICINAE_SETTINGS_FILE" ]] && return 0

    # This file intentionally remains mutable: Vicinae's GUI writes user
    # preferences here. Stable defaults live in the imported dotfiles file.
    cat >"$VICINAE_SETTINGS_FILE" <<EOF
{
  "\$schema": "https://vicinae.com/schemas/config.json",
  "imports": ["base.jsonc"],
  "providers": {
    "files": {
      "preferences": {
        "autoIndexing": true,
        "indexingPaths": [
          "$HOME/Downloads",
          "$HOME/Documents"
        ],
        "excludedIndexingPaths": []
      }
    }
  }
}
EOF
}

configure_scripts() {
    mkdir -p "$(dirname "$VICINAE_SCRIPTS_LINK")"

    if [[ -d "$VICINAE_SCRIPTS_LINK" && ! -L "$VICINAE_SCRIPTS_LINK" ]]; then
        if find "$VICINAE_SCRIPTS_LINK" -mindepth 1 -print -quit | grep -q .; then
            backup_real_path "$VICINAE_SCRIPTS_LINK"
        else
            rmdir "$VICINAE_SCRIPTS_LINK"
        fi
    else
        rm -f "$VICINAE_SCRIPTS_LINK"
    fi

    ln -s "$SCRIPT_DIR/scripts" "$VICINAE_SCRIPTS_LINK"
}

seed_initial_shortcuts() {
    # Shortcuts remain Vicinae-owned and editable. Seed one useful example only
    # when Vicinae has no shortcuts yet; never replace personal changes.
    if [[ ! -f "$VICINAE_SHORTCUTS_FILE" ]] \
        || jq -e 'length == 0' "$VICINAE_SHORTCUTS_FILE" &>/dev/null; then
        mkdir -p "$(dirname "$VICINAE_SHORTCUTS_FILE")"
        cp "$SCRIPT_DIR/shortcuts.json" "$VICINAE_SHORTCUTS_FILE"
    fi
}

configure_theme() {
    mkdir -p "$VICINAE_THEMES_DIR"
    ln -sfn "$SCRIPT_DIR/themes/everforest.toml" "$VICINAE_EVERFOREST_THEME_LINK"
}

configure_desktop_entries() {
    bootstrap_vicinae_path

    local vicinae_bin vicinae_root source target
    vicinae_bin="$(readlink -f "$(command -v vicinae)")"
    vicinae_root="${vicinae_bin%/bin/vicinae}"

    mkdir -p "$VICINAE_APPLICATIONS_DIR"
    for name in vicinae.desktop vicinae-url-handler.desktop; do
        source="$vicinae_root/share/applications/$name"
        target="$VICINAE_APPLICATIONS_DIR/$name"
        [[ -f "$source" ]] || continue

        if [[ -f "$target" ]] \
            && ! grep -q 'Managed by dotfiles/vicinae' "$target"; then
            backup_real_path "$target"
        fi

        # Desktop entries do not expand $HOME and the graphical session PATH
        # does not include the Nix profile, so write the absolute CLI path.
        sed \
            -e '/^\[Desktop Entry\]$/a # Managed by dotfiles/vicinae' \
            -e "s|^Exec=vicinae|Exec=$HOME/.nix-profile/bin/vicinae|" \
            "$source" >"$target"
    done

    if command -v update-desktop-database &>/dev/null; then
        update-desktop-database "$VICINAE_APPLICATIONS_DIR"
    fi

    if command -v xdg-mime &>/dev/null; then
        xdg-mime default vicinae-url-handler.desktop x-scheme-handler/vicinae
        xdg-mime default vicinae-url-handler.desktop x-scheme-handler/raycast
        xdg-mime default vicinae-url-handler.desktop x-scheme-handler/com.raycast
    fi
}

configure_service() {
    mkdir -p "$(dirname "$VICINAE_SERVICE_LINK")"
    backup_real_path "$VICINAE_SERVICE_LINK"
    ln -s "$SCRIPT_DIR/vicinae.service" "$VICINAE_SERVICE_LINK"

    systemctl --user daemon-reload
    systemctl --user enable --now vicinae.service
}

configure() {
    supported_platform || return 0

    mkdir -p "$VICINAE_CONFIG_DIR"
    rm -f "$VICINAE_BASE_LINK"
    ln -s "$SCRIPT_DIR/base.jsonc" "$VICINAE_BASE_LINK"
    create_initial_settings
    configure_scripts
    configure_theme
    configure_desktop_entries
    seed_initial_shortcuts

    chmod +x "$SCRIPT_DIR/scripts/"*.sh "$SCRIPT_DIR/setup-input-server"

    # This is a no-op when sudo credentials are not already available. The
    # script prints the one interactive command needed to finish paste support.
    "$SCRIPT_DIR/setup-input-server" --non-interactive

    configure_service
}

apply() {
    supported_platform || return 0
    configure
    systemctl --user try-restart vicinae.service 2>/dev/null || true
}

update() {
    install
    configure
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    install
    configure
fi
