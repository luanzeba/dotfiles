#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/../lib/nix.sh"

bootstrap_tmux_path() {
    _source_nix_env || true
    if [[ -d "$HOME/.nix-profile/bin" ]]; then
        export PATH="$HOME/.nix-profile/bin:$PATH"
    fi
}

check_installed() {
    if ! nix_profile_has_entry "$NIX_BASE_PROFILE_NAME"; then
        return 1
    fi

    bootstrap_tmux_path
    command -v tmux &>/dev/null
}

check_configured() {
    [[ -L "$HOME/.tmux.conf" ]]
}

get_installed_version() {
    bootstrap_tmux_path
    if command -v tmux &>/dev/null; then
        tmux -V 2>/dev/null || true
    fi
}

install() {
    # tmux is included in the shared Nix base profile.
    nix_profile_sync_base
}

configure() {
    ln -sf "$SCRIPT_DIR/.tmux.conf" ~/.tmux.conf
}

apply() {
    bootstrap_tmux_path

    # Reload tmux config if tmux is running
    if command -v tmux &>/dev/null && tmux list-sessions &>/dev/null; then
        tmux source-file ~/.tmux.conf
        echo "Reloaded tmux config"
    fi
}

update() {
    nix_profile_sync_base
}

# Main (only run when executed directly, not when sourced)
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    install
    configure
fi
