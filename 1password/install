#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/../lib/nix.sh"

bootstrap_onepassword_path() {
    _source_nix_env || true
    if [[ -d "$HOME/.nix-profile/bin" ]]; then
        export PATH="$HOME/.nix-profile/bin:$PATH"
    fi
}

check_installed() {
    if ! nix_profile_has_entry "$NIX_ONEPASSWORD_PROFILE_NAME"; then
        return 1
    fi

    bootstrap_onepassword_path
    command -v op &>/dev/null
}

check_configured() {
    # 1Password app integration is configured inside the app, not via dotfiles.
    return 0
}

get_installed_version() {
    bootstrap_onepassword_path
    if command -v op &>/dev/null; then
        op --version 2>/dev/null | awk '{print "op " $1}'
    fi
}

install() {
    nix_profile_sync_onepassword
}

configure() {
    bootstrap_onepassword_path

    if ! command -v op &>/dev/null; then
        echo "1Password CLI not installed, skipping configuration"
        return 0
    fi

    echo ""
    echo "To complete setup, enable CLI integration in the 1Password app:"
    echo "  1. Open 1Password"
    echo "  2. Go to Settings > Developer"
    echo "  3. Enable 'Integrate with 1Password CLI'"
    echo ""
}

update() {
    nix_profile_sync_onepassword
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    install
    configure
fi
