#!/bin/bash
#
# qmd-reindex: Re-index qmd collections and update embeddings.
# Designed to be run by a LaunchAgent on a schedule.
#

set -e

LOG_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/qmd"
LOG_FILE="$LOG_DIR/reindex.log"
mkdir -p "$LOG_DIR"

# Resolve symlinks to locate the dotfiles root (this script is linked to ~/.local/bin).
REAL_SCRIPT="$0"
while [[ -L "$REAL_SCRIPT" ]]; do
    LINK_DIR="$(cd -P "$(dirname "$REAL_SCRIPT")" && pwd)"
    REAL_SCRIPT="$(readlink "$REAL_SCRIPT")"
    [[ "$REAL_SCRIPT" != /* ]] && REAL_SCRIPT="$LINK_DIR/$REAL_SCRIPT"
done
SCRIPT_DIR="$(cd -P "$(dirname "$REAL_SCRIPT")" && pwd)"
DOTFILES_DIR="$(cd -P "$SCRIPT_DIR/.." && pwd)"

if [[ -f "$DOTFILES_DIR/lib/common.sh" ]]; then
    # shellcheck disable=SC1091
    source "$DOTFILES_DIR/lib/common.sh"
    bootstrap_node_tooling_path >/dev/null 2>&1 || true
else
    # Fallback bootstrap when dotfiles cannot be resolved.
    if [[ -d "$HOME/.nix-profile/bin" && ":$PATH:" != *":$HOME/.nix-profile/bin:"* ]]; then
        export PATH="$HOME/.nix-profile/bin:$PATH"
    fi
    if [[ -d "$HOME/.local/bin" && ":$PATH:" != *":$HOME/.local/bin:"* ]]; then
        export PATH="$HOME/.local/bin:$PATH"
    fi
fi

export PATH="$HOME/.local/bin:$PATH"

if ! command -v qmd &>/dev/null; then
    echo "$(date -Iseconds) qmd not found in PATH" >> "$LOG_FILE"
    exit 1
fi

{
    echo "$(date -Iseconds) Starting reindex..."
    qmd update 2>&1
    echo "$(date -Iseconds) Updating embeddings..."
    qmd embed 2>&1
    echo "$(date -Iseconds) Reindex complete."
} >> "$LOG_FILE" 2>&1

# Keep log file from growing forever (last 500 lines)
if [[ -f "$LOG_FILE" ]] && [[ $(wc -l < "$LOG_FILE") -gt 500 ]]; then
    tail -200 "$LOG_FILE" > "$LOG_FILE.tmp" && mv "$LOG_FILE.tmp" "$LOG_FILE"
fi
