#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
EXTERNAL_DIR="$SCRIPT_DIR/external"
SKILL_CREATOR_DIR="$EXTERNAL_DIR/skill-creator"
PI_SKILLS_DIR="$EXTERNAL_DIR/pi-skills"
PI_SKILLS_REPO="https://github.com/badlogic/pi-skills"
PRIVATE_DIR="$EXTERNAL_DIR/private"
PRIVATE_REPO="luanzeba/private-dotfiles"

check_installed() {
    # Check if required external skills have been downloaded.
    # Codespaces intentionally skip badlogic/pi-skills.
    if [[ -n "${CODESPACES:-}" ]]; then
        return 0
    else
        [[ -d "$PI_SKILLS_DIR/gccli" ]]
    fi
}

check_configured() {
    # Check if the dotfiles skill is properly symlinked
    [[ -L "$HOME/.config/opencode/skill/dotfiles" ]]
}

# Download skill-creator from Anthropic's skills repo
download_skill_creator() {
    local base_url="https://raw.githubusercontent.com/anthropics/skills/main/skills/skill-creator"
    local files=(
        "SKILL.md"
        "LICENSE.txt"
        "references/output-patterns.md"
        "references/workflows.md"
        "scripts/init_skill.py"
        "scripts/package_skill.py"
        "scripts/quick_validate.py"
    )

    echo "Downloading skill-creator from anthropics/skills..."
    mkdir -p "$SKILL_CREATOR_DIR/references" "$SKILL_CREATOR_DIR/scripts"

    local failed=0
    for file in "${files[@]}"; do
        if ! curl -sSL --fail "$base_url/$file" -o "$SKILL_CREATOR_DIR/$file" 2>/dev/null; then
            failed=1
            break
        fi
    done

    if [[ $failed -eq 1 ]]; then
        echo "WARNING: Failed to download skill-creator from GitHub."
        echo "  This may be due to:"
        echo "    - Network connectivity issues"
        echo "    - Changes in the anthropics/skills repository structure"
        echo "  You can manually install from: https://github.com/anthropics/skills"
        rm -rf "$SKILL_CREATOR_DIR"
        return 1
    fi

    chmod +x "$SKILL_CREATOR_DIR/scripts/"*.py 2>/dev/null || true
    echo "skill-creator downloaded successfully."
    return 0
}

# Clone or update badlogic/pi-skills (used for gccli skill)
# Local-only: skipped in Codespaces.
download_pi_skills() {
    if [[ -n "${CODESPACES:-}" ]]; then
        echo "Skipping badlogic/pi-skills in Codespaces"
        return 0
    fi

    echo "Fetching gccli skill from $PI_SKILLS_REPO..."

    if [[ -d "$PI_SKILLS_DIR/.git" ]]; then
        if ! git -C "$PI_SKILLS_DIR" pull --ff-only 2>/dev/null; then
            echo "WARNING: Failed to update badlogic/pi-skills (may have local changes)"
            return 1
        fi
    else
        if ! git clone --depth 1 "$PI_SKILLS_REPO" "$PI_SKILLS_DIR" 2>/dev/null; then
            echo "WARNING: Failed to clone badlogic/pi-skills"
            return 1
        fi
    fi

    echo "pi-skills fetched successfully."
    return 0
}

# Clone or update private-dotfiles repo (contains sensitive skills like copilot-policy-queries)
# This will fail gracefully in Codespaces due to GITHUB_TOKEN scope limitations
download_private_skills() {
    echo "Fetching private skills from $PRIVATE_REPO..."

    if [[ -d "$PRIVATE_DIR/.git" ]]; then
        # Update existing clone
        if ! git -C "$PRIVATE_DIR" pull --ff-only 2>/dev/null; then
            echo "WARNING: Failed to update private skills (may have local changes)"
            return 1
        fi
    else
        # Fresh clone - prefer gh if available (handles auth automatically)
        if command -v gh &>/dev/null && gh auth status &>/dev/null; then
            if ! gh repo clone "$PRIVATE_REPO" "$PRIVATE_DIR" -- --depth 1 2>/dev/null; then
                echo "WARNING: Failed to clone private skills."
                echo "  This is expected in Codespaces (GITHUB_TOKEN lacks access)."
                echo "  On local machines, ensure you have access to $PRIVATE_REPO"
                return 1
            fi
        else
            # Fall back to SSH
            if ! git clone --depth 1 "git@github.com:$PRIVATE_REPO.git" "$PRIVATE_DIR" 2>/dev/null; then
                echo "WARNING: Failed to clone private skills."
                echo "  This is expected in Codespaces (no SSH key)."
                echo "  On local machines:"
                echo "    - For SSH: Ensure your SSH key is set up"
                echo "    - Or install gh CLI and run 'gh auth login'"
                return 1
            fi
        fi
    fi

    echo "Private skills fetched successfully."
    return 0
}

# Download external skills (public repos, plus private if auth available)
# Note: skill-creator is now maintained locally in skills/skill-creator/
install() {
    download_pi_skills || echo "Continuing without gccli skill..."
    download_private_skills || echo "Continuing without private skills..."
}

# Symlink a skill to global locations
# Usage: symlink_skill <skill_path> <skill_name>
symlink_skill() {
    local skill_path="$1"
    local skill_name="$2"

    # Only link if the skill exists
    if [[ ! -d "$skill_path" ]]; then
        echo "Skill not found: $skill_path (skipping)"
        return 1
    fi

    # Remove existing symlinks/directories
    rm -rf ~/.config/opencode/skill/"$skill_name"
    rm -rf ~/.claude/skills/"$skill_name"
    rm -rf ~/.pi/agent/skills/"$skill_name"

    # Create new symlinks
    ln -s "$skill_path" ~/.config/opencode/skill/"$skill_name"
    ln -s "$skill_path" ~/.claude/skills/"$skill_name"
    ln -s "$skill_path" ~/.pi/agent/skills/"$skill_name"

    echo "Linked: $skill_name"
    return 0
}

# Create global skill directories and symlink all skills
configure() {
    # Create global skill directories
    mkdir -p ~/.config/opencode/skill
    mkdir -p ~/.claude/skills
    mkdir -p ~/.pi/agent/skills

    # Link custom skills from this repo (all directories except 'external')
    for skill_dir in "$SCRIPT_DIR"/*/; do
        local skill_name
        skill_name=$(basename "$skill_dir")
        # Skip the external directory (handled separately below)
        [[ "$skill_name" == "external" ]] && continue
        symlink_skill "$skill_dir" "$skill_name"
    done

    # Link external skills (skill-creator is now local, not external)
    # if [[ -d "$SKILL_CREATOR_DIR" ]]; then
    #     symlink_skill "$SKILL_CREATOR_DIR" "skill-creator"
    # fi

    # Link gccli skill from badlogic/pi-skills on local machines only
    if [[ -z "${CODESPACES:-}" && -d "$PI_SKILLS_DIR/gccli" ]]; then
        symlink_skill "$PI_SKILLS_DIR/gccli" "gccli"
    fi

    # Link private skills (each skill in private repo's skills/ directory)
    # These contain sensitive content and won't be available in Codespaces
    if [[ -d "$PRIVATE_DIR/skills" ]]; then
        for skill_dir in "$PRIVATE_DIR/skills"/*/; do
            if [[ -d "$skill_dir" ]]; then
                local skill_name
                skill_name=$(basename "$skill_dir")
                symlink_skill "$skill_dir" "$skill_name"
            fi
        done
    fi
}

# Install tools from private-dotfiles (iq, splunk-cli)
install_private_tools() {
    if [[ -x "$PRIVATE_DIR/install" ]]; then
        echo ""
        echo "Installing private tools..."
        "$PRIVATE_DIR/install"
    fi
}

# Install npm dependencies for skills that need them
install_skill_dependencies() {
    # web-browser skill needs ws (WebSocket) package for CDP communication
    local web_browser_scripts="$SCRIPT_DIR/web-browser/scripts"
    if [[ -f "$web_browser_scripts/package.json" ]]; then
        echo ""
        echo "Installing web-browser dependencies..."
        (cd "$web_browser_scripts" && npm install) || echo "WARNING: web-browser npm install had issues"
    fi
}

# Main (only run when executed directly, not when sourced)
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    echo "Installing skills..."
    install
    configure
    install_private_tools
    install_skill_dependencies
    echo ""
    echo "Skills installation complete!"
    echo ""
    echo "Installed skills:"
    ls -la ~/.config/opencode/skill/
fi
